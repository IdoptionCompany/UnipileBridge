# ─── Unipile API ──────────────────────────────────────────────────────────────

# Your Unipile DSN — copy from app.unipile.com → API Keys → "DSN"
# Format: https://apiXX.unipile.com:XXXXX
UNIPILE_BASE_URL=https://api42.unipile.com:17207

# Your Unipile API key — copy from app.unipile.com → API Keys → "Copy" button
UNIPILE_SHARED_KEY=your_unipile_api_key_here

# ─── User routing ─────────────────────────────────────────────────────────────

# Maps each Dust user email to their Unipile account_id
# Get account_ids by calling list_accounts after deployment
# Format: email:account_id,email:account_id (no spaces)
ACCOUNT_MAP=ian@yourcompany.com:unipile_account_id_ian,alice@yourcompany.com:unipile_account_id_alice

# Per-user Unipile API keys (only needed if each user has their own Unipile account)
# Leave empty if everyone shares the same UNIPILE_SHARED_KEY
USER_MAP=

# ─── OAuth (per-user auth via Dust Static OAuth + Personal accounts) ──────────

# Public URL of this bridge (token issuer + audience). No trailing slash.
PUBLIC_BASE_URL=https://unipilebridge-production.up.railway.app

# HS256 signing key for access/refresh tokens. REQUIRED, must be >= 32 bytes.
# Generate with: openssl rand -base64 48
OAUTH_JWT_SECRET=

# Static OAuth client you paste into Dust (Static OAuth → Personal accounts).
OAUTH_CLIENT_ID=dust-unipile-bridge
OAUTH_CLIENT_SECRET=

# Redirect URI Dust uses (its fixed value; override only if Dust changes it).
OAUTH_REDIRECT_URI=https://dust.tt/oauth/mcp_static/finalize
OAUTH_SCOPE=mcp

# Personal access codes each user enters once at the login page: code:email,code:email
TOKEN_MAP=ian-personal-code:ian@idoption.ai,bap-personal-code:baptiste@idoption.ai

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on (Railway injects this automatically, keep at 3000)
PORT=3000