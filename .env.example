# ─── Unipile API ──────────────────────────────────────────────────────────────

# Your Unipile DSN — copy from app.unipile.com → API Keys → "DSN"
# Format: https://apiXX.unipile.com:XXXXX
UNIPILE_BASE_URL=https://api42.unipile.com:17207

# Your Unipile API key — copy from app.unipile.com → API Keys → "Copy" button
UNIPILE_SHARED_KEY=your_unipile_api_key_here

# ─── User routing ─────────────────────────────────────────────────────────────

# Maps each Dust user email to their Unipile account_id
# Get account_ids by calling list_accounts after deployment
# Format: email:account_id,email:account_id (no spaces)
ACCOUNT_MAP=ian@yourcompany.com:unipile_account_id_ian,alice@yourcompany.com:unipile_account_id_alice

# Per-user Unipile API keys (only needed if each user has their own Unipile account)
# Leave empty if everyone shares the same UNIPILE_SHARED_KEY
USER_MAP=

# ─── Bridge security ──────────────────────────────────────────────────────────

# Secret token Dust uses to authenticate to the bridge
# Generate with: openssl rand -base64 32
BRIDGE_AUTH_TOKEN=your_secret_bridge_token_here

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the server listens on (Railway injects this automatically, keep at 3000)
PORT=3000